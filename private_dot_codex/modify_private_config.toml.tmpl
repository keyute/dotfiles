{{- $codex := .agents.codex -}}
{{- $sandbox := includeTemplate "agent-sandbox" (dict "self" "codex" "root" .) | fromJson -}}
{{- $filesystem := dict -}}
{{- $workspaceFilesystem := dict -}}
{{- /* deny uses $sandbox.denyRead (not sandboxDenyRead) on purpose: this single
       permission profile is Codex's only file-access gate, so it must carry the
       UNION of what claude splits across its OS sandbox (sandboxDenyRead) and its
       Read-tool deny (full denyRead) — i.e. Codex's own home-sensitive paths too.
       Codex reads its own auth.json/config.toml outside the sandbox, so denying
       them to tools is the intended guard. Do not switch this to sandboxDenyRead;
       that would let Codex tools read their own credentials and weaken parity. */ -}}
{{- $modeGroups := list
      (dict "mode" "write" "paths" $sandbox.allowWrite)
      (dict "mode" "read" "paths" $sandbox.allowRead)
      (dict "mode" "deny" "paths" $sandbox.denyRead) -}}
{{- range $group := $modeGroups -}}
  {{- range $path := $group.paths -}}
    {{- $expanded := $path -}}
    {{- if hasPrefix "~/" $expanded -}}
      {{- $expanded = printf "%s/%s" $.chezmoi.homeDir (trimPrefix "~/" $expanded) -}}
    {{- end -}}
    {{- if hasPrefix "/" $expanded -}}
      {{- $_ := set $filesystem $expanded $group.mode -}}
    {{- else -}}
      {{- $_ := set $workspaceFilesystem $expanded $group.mode -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $fsTable := $filesystem -}}
{{- if $workspaceFilesystem -}}
  {{- $fsTable = set $fsTable ":workspace_roots" $workspaceFilesystem -}}
{{- end -}}
{{- $domainsTable := dict -}}
{{- range concat .agent_sandbox.network.allowed_domains $codex.extras.allowed_domains | uniq | sortAlpha -}}
  {{- $domainsTable = set $domainsTable . "allow" -}}
{{- end -}}
{{- $deletes := list
      "model"
      "model_reasoning_effort"
      "plan_mode_reasoning_effort"
      "approval_policy"
      "default_permissions"
      "features.network_proxy"
      "permissions.chezmoi-workspace" -}}
{{- $mcpServers := dict -}}
{{- range $name, $entry := includeTemplate "mcp-servers" . | fromJson -}}
  {{- if not (regexMatch "^[A-Za-z0-9_-]+$" $name) -}}
    {{- fail (printf "Codex MCP server name %q must be a bare TOML key (it is used in a dotted delete path)" $name) -}}
  {{- end -}}
  {{- $deletes = append $deletes (printf "mcp_servers.%s" $name) -}}
  {{- if eq $entry.type "http" -}}
    {{- $mcpServers = set $mcpServers $name (dict "url" $entry.url) -}}
  {{- else -}}
    {{- $server := dict "command" $entry.command "args" $entry.args -}}
    {{- if $entry.env -}}
      {{- $server = set $server "env" $entry.env -}}
    {{- end -}}
    {{- $mcpServers = set $mcpServers $name $server -}}
  {{- end -}}
{{- end -}}
{{- /* tui is fully managed for cross-machine TUI consistency: status_line and
       status_line_use_colors are re-emitted via managed below, while tui.theme is
       deleted and deliberately NOT re-emitted (managed-to-absence) so every
       machine runs Codex's default theme detection and none can drift. */ -}}
{{- $deletes = concat $deletes (list "tui.status_line" "tui.status_line_use_colors" "tui.theme") -}}
{{- $managed := dict
      "model" $codex.defaults.model
      "model_reasoning_effort" $codex.defaults.model_reasoning_effort
      "plan_mode_reasoning_effort" $codex.defaults.plan_mode_reasoning_effort
      "approval_policy" "on-request"
      "default_permissions" "chezmoi-workspace"
      "features" (dict "network_proxy" (dict "enabled" true))
      "permissions" (dict "chezmoi-workspace" (dict
          "description" "Workspace writes with shared sensitive-path and network controls"
          "extends" ":workspace"
          "filesystem" $fsTable
          "network" (dict
              "enabled" true
              "mode" "limited"
              "allow_local_binding" .agent_sandbox.network.allow_local_binding
              "domains" $domainsTable)))
      "mcp_servers" $mcpServers
      "tui" (dict
          "status_line" (list "model-with-reasoning" "context-used" "five-hour-limit" "weekly-limit" "git-branch" "branch-changes")
          "status_line_use_colors" true) -}}
{{- $manifest := dict "delete" $deletes "managed" $managed -}}
#!/usr/bin/env bash
# Partial management of ~/.codex/config.toml: the merge script replaces the keys
# chezmoi owns (listed in the manifest's delete/managed entries) and preserves
# everything else Codex writes at runtime (trusted projects, notices, ...).
set -euo pipefail

{
  cat <<'CHEZMOI_MANIFEST_JSON'
{{ $manifest | toJson }}
CHEZMOI_MANIFEST_JSON
  cat
} | node "{{ .chezmoi.sourceDir }}/scripts/merge-codex-config.mjs"
