#!/usr/bin/env bash
set -euo pipefail

input=$(cat)

# Strip the old managed block plus sections managed by chezmoi. Preserve user/TUI
# tables, and keep unknown top-level keys at top-level.
cleaned=$(printf '%s' "$input" | awk '
  /^[[:space:]]*# >>> chezmoi managed >>>[[:space:]]*$/ { next }
  /^[[:space:]]*# <<< chezmoi managed <<<[[:space:]]*$/ { next }
  /^[[:space:]]*\[mcp_servers(\.|])/                    { m=1; next }
  /^[[:space:]]*\[permissions(\.|])/                    { m=1; next }
  /^[[:space:]]*\[sandbox_workspace_write(\.|])/        { m=1; next }
  m && /^[[:space:]]*\[/                                { m=0 }
  m                                                     { next }
                                                        { print }
')

preserved_top=$(printf '%s\n' "$cleaned" | awk '
  /^[[:space:]]*\[/                                  { t=1 }
  t                                                  { next }
  /^[[:space:]]*plan_mode_reasoning_effort[[:space:]]*=/ { next }
  /^[[:space:]]*model_instructions_file[[:space:]]*=/     { next }
  /^[[:space:]]*approval_policy[[:space:]]*=/             { next }
  /^[[:space:]]*approvals_reviewer[[:space:]]*=/           { next }
  /^[[:space:]]*default_permissions[[:space:]]*=/          { next }
  /^[[:space:]]*permission_profile[[:space:]]*=/           { next }
  /^[[:space:]]*sandbox_mode[[:space:]]*=/                 { next }
                                                     { print }
')

preserved_tables=$(printf '%s\n' "$cleaned" | awk '
  /^[[:space:]]*\[/ { t=1 }
  t                 { print }
')

trim_leading_blank_lines() {
  awk 'seen || $0 !~ /^[[:space:]]*$/ { seen=1; print }'
}

cat <<'CHEZMOI_MANAGED_BLOCK'
# >>> chezmoi managed >>>
plan_mode_reasoning_effort = "xhigh"
approval_policy = "on-request"
approvals_reviewer = "user"
default_permissions = "workspace"
CHEZMOI_MANAGED_BLOCK

if [ -n "$preserved_top" ]; then
  printf '\n%s\n' "$preserved_top" | trim_leading_blank_lines
fi

cat <<'CHEZMOI_MANAGED_BLOCK'
[permissions.workspace.filesystem]
":project_roots" = { "." = "write" }
{{- range .agent_sandbox.filesystem.deny_read }}
{{ . | toJson }} = "none"
{{- end }}
{{- range .agent_sandbox.filesystem.allow_write }}
{{ . | toJson }} = "write"
{{- end }}

[permissions.workspace.network]
enabled = true
mode = "full"

[permissions.workspace.network.domains]
{{- range .agent_sandbox.network.allowed_domains }}
{{ . | toJson }} = "allow"
{{- end }}

{{ range $name, $cfg := .agent_mcp_servers }}
[mcp_servers.{{ $name | toJson }}]
{{- $command := get $cfg "command" -}}
{{- if not $command -}}
{{- $command = printf "%s/node_modules/.bin/%s" $.chezmoi.sourceDir $cfg.package_bin -}}
{{- end }}
command = {{ $command | toJson }}
args = [
{{- range $cfg.args }}
  {{- if kindIs "map" . }}
    {{- $ref := .op -}}
    {{- if not (hasPrefix "op://" $ref) -}}
      {{- $ref = printf "op://%s" $ref -}}
    {{- end }}
  {{ onepasswordRead $ref | toJson }},
  {{- else }}
  {{ . | toJson }},
  {{- end }}
{{- end }}
]
{{- $env := default (dict) (get $cfg "env") -}}
{{- if $env }}

[mcp_servers.{{ $name | toJson }}.env]
{{- range $key, $value := $env }}
  {{- if kindIs "map" $value }}
    {{- $ref := $value.op -}}
    {{- if not (hasPrefix "op://" $ref) -}}
      {{- $ref = printf "op://%s" $ref -}}
    {{- end }}
{{ $key | toJson }} = {{ onepasswordRead $ref | toJson }}
  {{- else }}
{{ $key | toJson }} = {{ $value | toJson }}
  {{- end }}
{{- end }}
{{- end }}
{{ end -}}
# <<< chezmoi managed <<<
CHEZMOI_MANAGED_BLOCK

if [ -n "$preserved_tables" ]; then
  printf '\n%s\n' "$preserved_tables" | trim_leading_blank_lines
fi
