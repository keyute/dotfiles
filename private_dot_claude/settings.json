{
  "permissions": {
    "allow": [
      "mcp__context7",
      "WebSearch",
      "WebFetch"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "theme": "auto",
  "sandbox": {
    "enabled": true
  }
}
