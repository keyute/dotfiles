{{- $denyRead := list -}}
{{- $sandboxDenyRead := list -}}
{{- $allowRead := list -}}
{{- $allowWrite := list -}}
{{- range $path, $mode := .agent_sandbox.filesystem.paths -}}
  {{- if eq $mode "none" -}}
    {{- $denyRead = append $denyRead $path -}}
    {{- $sandboxDenyRead = append $sandboxDenyRead $path -}}
  {{- else if eq $mode "read" -}}{{- $allowRead = append $allowRead $path -}}
  {{- else if eq $mode "write" -}}{{- $allowWrite = append $allowWrite $path -}}
  {{- end -}}
{{- end -}}
{{- range $name, $agent := .agents -}}
  {{- $denyRead = append $denyRead $agent.home -}}
  {{- if ne $name "claude" -}}
    {{- $sandboxDenyRead = append $sandboxDenyRead $agent.home -}}
  {{- end -}}
{{- end -}}
{{- range .agents.claude.extras.readable_paths -}}
  {{- $allowRead = append $allowRead . -}}
{{- end -}}
{{- range .agents.claude.extras.writable_paths -}}
  {{- $allowWrite = append $allowWrite . -}}
{{- end -}}
{{- $allowedDomains := concat .agent_sandbox.network.allowed_domains .agents.claude.extras.allowed_domains -}}
{{- $uid := output "id" "-u" | trim -}}
{{- $allowedPerms := list "WebSearch" "WebFetch" -}}
{{- range $name, $cfg := .agent_mcp_servers -}}
  {{- $allowedPerms = append $allowedPerms (printf "mcp__%s" $name) -}}
{{- end -}}
{{- range .agents.claude.extras.allowed_read_patterns -}}
  {{- $allowedPerms = append $allowedPerms (printf "Read(%s)" (replace "{uid}" $uid .)) -}}
{{- end -}}
{{- $permDeny := list -}}
{{- range $denyRead -}}{{- $permDeny = append $permDeny (printf "Read(%s)" .) -}}{{- end -}}
{
  "permissions": {
    "allow": {{ $allowedPerms | toJson }},
    "deny": {{ $permDeny | toJson }},
    "defaultMode": "plan"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.sourceDir }}/node_modules/.bin/ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {{ .agents.claude.plugins | toJson }},
  "extraKnownMarketplaces": {{ .agents.claude.marketplaces | toJson }},
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": {{ $allowedDomains | uniq | toJson }}
    },
    "filesystem": {
      "allowWrite": {{ $allowWrite | toJson }},
      "allowRead": {{ $allowRead | toJson }},
      "denyRead": {{ $sandboxDenyRead | toJson }}
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "theme": "auto",
  "agentPushNotifEnabled": false
}
