{{- $denyRead := list -}}
{{- $allowRead := list -}}
{{- $allowWrite := list -}}
{{- range $path, $mode := .agent_sandbox.filesystem.paths -}}
  {{- if eq $mode "none" -}}{{- $denyRead = append $denyRead $path -}}
  {{- else if eq $mode "read" -}}{{- $allowRead = append $allowRead $path -}}
  {{- else if eq $mode "write" -}}{{- $allowWrite = append $allowWrite $path -}}
  {{- end -}}
{{- end -}}
{{- $permDeny := list -}}
{{- range $denyRead -}}{{- $permDeny = append $permDeny (printf "Read(%s)" .) -}}{{- end -}}
{
  "permissions": {
    "allow": [
      "mcp__context7",
      "WebSearch",
      "WebFetch"
    ],
    "deny": {{ $permDeny | toJson }},
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.sourceDir }}/node_modules/.bin/ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": {{ .agent_sandbox.network.allowed_domains | toJson }}
    },
    "filesystem": {
      "allowWrite": {{ $allowWrite | toJson }},
      "allowRead": {{ $allowRead | toJson }},
      "denyRead": {{ $denyRead | toJson }}
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "theme": "auto",
  "agentPushNotifEnabled": false
}
