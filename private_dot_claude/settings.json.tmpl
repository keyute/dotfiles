{{- $sb := fromJson (includeTemplate "agent-sandbox" (dict "self" "claude" "root" .)) -}}
{{- $allowRead := $sb.allowRead -}}
{{- $allowWrite := $sb.allowWrite -}}
{{- $sandboxDenyRead := $sb.sandboxDenyRead -}}
{{- $extras := .agents.claude.extras -}}
{{- range $extras.readable_paths -}}
  {{- $allowRead = append $allowRead . -}}
{{- end -}}
{{- range $extras.writable_paths -}}
  {{- $allowWrite = append $allowWrite . -}}
{{- end -}}
{{- $allowedDomains := concat .agent_sandbox.network.allowed_domains $extras.allowed_domains -}}
{{- $uid := output "id" "-u" | trim -}}
{{- $allowedPerms := list "WebSearch" "WebFetch" -}}
{{- range $name, $cfg := .agent_mcp_servers -}}
  {{- $allowedPerms = append $allowedPerms (printf "mcp__%s" $name) -}}
{{- end -}}
{{- range $extras.allowed_read_patterns -}}
  {{- $allowedPerms = append $allowedPerms (printf "Read(%s)" (replace "{uid}" $uid .)) -}}
{{- end -}}
{{- $permDeny := list -}}
{{- range $sb.denyRead -}}{{- $permDeny = append $permDeny (printf "Read(%s)" .) -}}{{- end -}}
{
  "permissions": {
    "allow": {{ $allowedPerms | toPrettyJson | indent 4 | trim }},
    "deny": {{ $permDeny | toPrettyJson | indent 4 | trim }},
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "worktree": {
    "baseRef": "head"
  },
  "disableRemoteControl": true,
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.sourceDir }}/node_modules/.bin/ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {{ .agents.claude.plugins | toPrettyJson | indent 2 | trim }},
  "extraKnownMarketplaces": {{ .agents.claude.marketplaces | toPrettyJson | indent 2 | trim }},
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": {{ $allowedDomains | uniq | toPrettyJson | indent 6 | trim }},
      "allowLocalBinding": {{ .agent_sandbox.network.allow_local_binding }}
    },
    "filesystem": {
      "allowWrite": {{ $allowWrite | toPrettyJson | indent 6 | trim }},
      "denyRead": {{ $sandboxDenyRead | toPrettyJson | indent 6 | trim }},
      "allowRead": {{ $allowRead | toPrettyJson | indent 6 | trim }}
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": false,
  "disableDeepLinkRegistration": "disable"
}
