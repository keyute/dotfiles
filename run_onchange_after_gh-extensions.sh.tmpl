#!/bin/bash
# Idempotent install of gh CLI extensions. Runs after run_onchange_after_brew
# (which installs gh), and no-ops on hosts where gh is absent.
#   dlvhdr/gh-dash    — PR/issue dashboard
#   dlvhdr/gh-enhance — GitHub Actions TUI, launched from gh-dash's PR view (T)
set -euo pipefail

command -v gh >/dev/null 2>&1 || exit 0

# Snapshot installed extensions once, then guard each install so re-runs are no-ops.
# NB: don't pipe into `grep -q` — its early exit SIGPIPEs `gh extension list`, which
# under `pipefail` makes the pipeline exit 141 and wrongly re-triggers the install.
installed="$(gh extension list 2>/dev/null || true)"

for ext in dlvhdr/gh-dash dlvhdr/gh-enhance; do
  case "$installed" in
    *"$ext"*) ;;                          # already installed → skip
    *) gh extension install "$ext" ;;
  esac
done
