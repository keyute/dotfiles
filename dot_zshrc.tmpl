if [[ $SHLVL -eq 1 ]]; then
  printf '\n%.0s' {1..$LINES}
fi

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

alias python='python3'
alias lg='lazygit'
alias lzd='lazydocker'
alias lsql='lazysql'

# `gh` handles both hosts (auto-detects host from a repo's remote). `ghe` forces the
# GHES host for repo-independent commands and for gh-dash (`ghe dash`).
ghe() { GH_HOST=git.kubecity.com gh "$@"; }

if type brew &>/dev/null; then
    FPATH="$(brew --prefix)/share/zsh/site-functions:$(brew --prefix)/share/zsh-completions:$FPATH"
fi

# User completions (e.g. _docker generated from the docker CLI; see run_onchange_after_docker-completion)
FPATH="$HOME/.local/share/zsh/site-functions:$FPATH"

zmodload zsh/complist
autoload -U compinit; compinit
_comp_options+=(globdots)

source $HOME/.local/share/antidote/antidote.zsh
antidote load

zstyle ':completion:complete:git-*:argument-rest' sort false

typeset -g _APPEARANCE=""
_sync_appearance() {
    local mode=$(theme-mode 2>/dev/null || echo dark)
    [[ $mode == $_APPEARANCE ]] && return
    _APPEARANCE=$mode
    export LC_THEME_MODE=$mode
    if [[ $mode == light ]]; then
        zstyle ':fzf-tab:*' default-color $'\033[30m'
        zstyle ':fzf-tab:*' fzf-flags --color=light
        export BAT_THEME="Catppuccin Latte"
        export K9S_SKIN="catppuccin-latte"
        export GH_DASH_CONFIG="$HOME/.config/gh-dash/config.catppuccin-latte.yml"
    else
        zstyle -d ':fzf-tab:*' default-color
        zstyle -d ':fzf-tab:*' fzf-flags
        export BAT_THEME="Catppuccin Mocha"
        export K9S_SKIN="catppuccin-mocha"
        export GH_DASH_CONFIG="$HOME/.config/gh-dash/config.catppuccin-mocha.yml"
    fi
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _sync_appearance

eval "$(zoxide init zsh --cmd cd)"

bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

export PATH="$PATH:$HOME/.local/bin"
{{- if eq .chezmoi.os "linux" }}
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
{{- end }}

export GOPRIVATE="git.keyute.io"
export GOPATH="$HOME/.go"
export PATH="$GOPATH/bin:$PATH"

export XDG_CONFIG_HOME="$HOME/.config"

alias vim=nvim
alias vi=nvim
alias cat='bat --paging=never'
export EDITOR="nvim"

export HISTFILE="$HOME/.zhistory"
export HISTSIZE=1000000000
export SAVEHIST=1000000000
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_IGNORE_ALL_DUPS

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
